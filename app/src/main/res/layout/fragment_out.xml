<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="16dp">

    <!-- ======================== -->
    <!--       User Info Card     -->
    <!-- ======================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/userCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Name -->
        <TextView
            android:id="@+id/labelName"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name:"
            android:textColor="@color/colorTextSecondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvName"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Пример имени"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/labelName"
            app:layout_constraintStart_toEndOf="@id/labelName"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Surname -->
        <TextView
            android:id="@+id/labelSName"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SName:"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelName"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvSName"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Пример фамилии"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvName"
            app:layout_constraintStart_toEndOf="@id/labelSName"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Activity -->
        <TextView
            android:id="@+id/labelActivity"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activity:"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelSName"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvActivity"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Пример деятельности"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvSName"
            app:layout_constraintStart_toEndOf="@id/labelActivity"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Class ID -->
        <TextView
            android:id="@+id/labelClassID"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Class ID:"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelActivity"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvClassID"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="12345"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvActivity"
            app:layout_constraintStart_toEndOf="@id/labelClassID"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Task ID -->
        <TextView
            android:id="@+id/labelTaskID"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task ID:"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelClassID"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvTaskID"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="98765"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvClassID"
            app:layout_constraintStart_toEndOf="@id/labelTaskID"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Оценка -->
        <TextView
            android:id="@+id/labelScore"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Оценка:"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelTaskID"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvScore"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="5"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTaskID"
            app:layout_constraintStart_toEndOf="@id/labelScore"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>